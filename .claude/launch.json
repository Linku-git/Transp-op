{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--host", "0.0.0.0", "--port", "5173"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "mobile",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run"],
      "port": 3000
    }
  ]
}
